# Library service configuration.
# Copy to `.env` and adjust as needed. All keys are read by cmd/library/config.go
# via viper with the prefix LIBRARY_ (e.g. LIBRARY_HTTP_PORT).

# HTTP server port the library binary listens on.
LIBRARY_HTTP_PORT=3000

# Postgres connection string used by both the application runtime and atlas migrations.
LIBRARY_DATABASE_URL=postgres://library:library@localhost:5432/library?sslmode=disable

# Redis connection string for caches and (future) chat/session storage.
LIBRARY_REDIS_URL=redis://localhost:6379/0

# Logger level: one of debug | info | warn | error.
LIBRARY_LOG_LEVEL=info

# Logger output format: one of json | text.
LIBRARY_LOG_FORMAT=json
